# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Public app URL used by metadata, sitemap, robots and password reset redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# IANA timezone used by the server to resolve "today" for access and schedules
APP_TIMEZONE=America/Sao_Paulo

# Public contact links shown on the landing and blocked-access pages
NEXT_PUBLIC_CONTACT_WHATSAPP_URL=https://wa.me/5500000000000
NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com

# Optional Sentry reporting
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_CSP_REPORT_URI=

# Optional E2E settings
E2E_BASE_URL=http://127.0.0.1:3000
E2E_MEMBER_EMAIL=member@example.com
E2E_MEMBER_PASSWORD=change-me
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=change-me
E2E_TARGET_MEMBER_EMAIL=member@example.com
