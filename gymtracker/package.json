{
  "name": "gymtracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:stable": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "lint": "eslint",
    "test": "vitest run --config vitest.config.mjs",
    "test:watch": "vitest --config vitest.config.mjs",
    "test:coverage": "vitest run --config vitest.config.mjs --coverage",
    "test:e2e": "playwright test",
    "test:e2e:public": "playwright test --no-deps --grep public --project=desktop-chrome --project=mobile-chrome",
    "test:e2e:auth": "playwright test --grep-invert public --project=desktop-chrome --project=mobile-chrome",
    "bootstrap:admin": "tsx scripts/bootstrap-admin.ts",
    "reconcile:exercise-history": "tsx scripts/reconcile-custom-exercise-history.ts",
    "cleanup:custom-exercises": "tsx scripts/cleanup-custom-exercises-without-history.ts"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.6",
    "next-intl": "^4.11.2",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
